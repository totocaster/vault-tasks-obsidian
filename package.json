{
	"name": "vault-tasks-view",
	"version": "0.9.0",
	"description": "Collects Markdown tasks from every note into a grouped task view.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
		"check": "tsc --noEmit --skipLibCheck",
		"test": "tsx --test tests/**/*.test.ts"
	},
	"keywords": [
		"obsidian",
		"tasks"
	],
	"author": "Toto Tvalavadze",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.16.5",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.25.4",
		"obsidian": "latest",
		"tsx": "^4.20.6",
		"typescript": "^5.6.3"
	}
}
