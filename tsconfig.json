{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2018",
		"allowJs": false,
		"noImplicitAny": true,
		"strict": true,
		"strictNullChecks": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"lib": [
			"DOM",
			"ES2018"
		],
		"types": [
			"node"
		]
	},
	"include": [
		"main.ts"
	]
}
